{
  "name": "careit-tracker",
  "displayName": "CareIt Productivity Tracker",
  "description": "Tracks your coding activity for the CareIt dashboard",
  "version": "0.0.4",
  "publisher": "SanjayGehlot",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sanjaygehlot1/CareIt/tree/main/vscode-extension/careit"
  },
  "icon": "icon.png",
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "careit.sendNow",
        "title": "CareIt: Force Send Analytics"
      }
    ],
    "configuration": {
      "title": "CareIt",
      "properties": {
        "careit.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your CareIt Personal API Key (Get it from https://careit.sanjaycodes.dev/settings)"
        },
        "careit.serverUrl": {
          "type": "string",
          "default": "https://api.careit.sanjaycodes.dev",
          "description": "The URL of the CareIt backend server (default is https://api.careit.sanjaycodes.dev)"
        },
        "careit.breakReminderMinutes": {
          "type": "number",
          "default": 90,
          "minimum": 1,
          "maximum": 480,
          "description": "Minutes of continuous coding before showing a break reminder (0 to disable)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.106.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
