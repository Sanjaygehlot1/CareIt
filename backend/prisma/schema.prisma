generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  provider   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  profileUrl String?
  calendar   Boolean  @default(false)

  googleAccessToken  String?
  googleRefreshToken String?
  googleProviderId   String? @unique

  githubRefreshToken      String?
  githubAccessToken       String?
  githubConnected         Boolean @default(false)
  githubProviderId        String? @unique
  githubUsername          String?
  githubAppInstallationId Int?
  githubAppInstalled      Boolean @default(false)

  apiKey          String?   @unique
  currentStreak        Int       @default(0)
  longestStreak        Int       @default(0)
  streakUpdatedAt      DateTime?
  streakEmailReminder  Boolean   @default(true)
  dailyDigestEnabled   Boolean   @default(true)  


  burnoutScore         Int       @default(0)      
  burnoutLevel         BurnoutLevel @default(NONE)
  burnoutAlertedAt     DateTime?                 


  streakCoachAlertedAt DateTime?                  
  streakCoachType      String?                    

  editorActivities EditorActivity[]
  focusStats       FocusStats[]
  streakStats      StreakStats[]
  goals            Goal[]
  notes            Note[]

  @@map("users")
}

model EditorActivity {
  id          Int      @id @default(autoincrement())
  duration    Int      @default(0)
  projectName String?
  userId      Int
  date        DateTime @db.Date
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, projectName, date])
}

model FocusStats {
  id        Int      @id @default(autoincrement())
  duration  Int      @default(0)
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model StreakStats {
  id             Int      @id @default(autoincrement())
  userId         Int
  date           DateTime @db.Date
  hasStreak      Boolean  @default(false)
  codingDuration Int      @default(0)
  commitCount    Int      @default(0)
  todayPriority  String?              // user-set or AI-generated priority for the day
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model Goal {
  id          Int        @id @default(autoincrement())
  userId      Int
  title       String
  description String?
  type        GoalType   @default(CUSTOM)
  period      GoalPeriod @default(WEEKLY)
  targetValue Float      
  currentValue Float     @default(0)
  unit        String     @default("") 
  completed   Boolean    @default(false)
  isAiGenerated Boolean  @default(false)
  weekStart   DateTime?  @db.Date 
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])
}

enum GoalType {
  CODING_TIME
  STREAK
  COMMITS
  FOCUS_TIME
  CUSTOM
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum BurnoutLevel {
  NONE
  MILD
  MODERATE
  SEVERE
}

model Note {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String   @default("Untitled")
  content   String   @default("")
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}
